# Runtime
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/sn-enterprises

# Auth
JWT_SECRET=replace_this_with_a_strong_secret
JWT_EXPIRES_IN=7d

# Frontend URL (comma separated values allowed)
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# SMTP Email (for forgot password + enquiry notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="S N Enterprises <noreply@snenterprises.in>"
ADMIN_EMAIL=admin@snenterprises.com

# Seed defaults
ADMIN_SEED_EMAIL=admin@snenterprises.com
ADMIN_SEED_PASSWORD=Admin@123
